# Reference for local development. These are read from process.env (the app
# does not auto-load .env), so either export them in your shell or use the
# provided npm scripts. The quickest path for email testing:
#   npm run mail:up    # start Mailpit
#   npm run dev:mail   # dev server with SMTP_HOST/SMTP_PORT already set

# Long random string for signing session cookies (openssl rand -hex 32)
# SESSION_SECRET=

# SQLite database path (default: ./data/reservation.db)
# DATABASE_PATH=./data/reservation.db

# Email / SMTP.
# Point these at Mailpit for local testing (see docker-compose.yml):
#   npm run mail:up   # start Mailpit, UI at http://localhost:8025
# When SMTP_HOST is set the app sends real emails via SMTP; otherwise
# verification/reset links are logged to the console.
SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
# MAIL_FROM=Terrible Football Liverpool <no-reply@tf-liverpool.local>

# Base URL used to build links in emails (defaults to http://localhost:5173)
# ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# Production email via Amazon SES (tenant "terriblefootball", region eu-west-2)
# Uses SMTP with SES tenant attribution headers. Set these instead of the
# Mailpit values above. The From-domain MUST be mail-zb.terriblefootball.net.
# ---------------------------------------------------------------------------
# SMTP_HOST=email-smtp.eu-west-2.amazonaws.com
# SMTP_PORT=587
# SMTP_SECURE=false                       # 587 uses STARTTLS (required when SES_TENANT is set)
# SMTP_USER=<SES SMTP username>
# SMTP_PASS=<SES SMTP password>
# MAIL_FROM=Terrible Football Liverpool <noreply@mail-zb.terriblefootball.net>
# SES_TENANT=terriblefootball             # REQUIRED for SES tenant attribution (adds X-SES-TENANT)
# SES_CONFIGURATION_SET=terriblefootball-default
